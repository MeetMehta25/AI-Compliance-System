# =========================================================================
# ComplianceAI Environment Variables Template
# Copy this file to '.env' (for local backend running) or configure these
# variables in your cloud deployment settings (Render / Vercel).
# =========================================================================

# ----------------- Gemini API Configuration -----------------
# Required: Your Gemini API Key from Google AI Studio.
# Get one here: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ----------------- Backend JWT Authentication -----------------
# Required: Secret key to sign JWT tokens. Run `openssl rand -hex 32` to generate a secure one.
JWT_SECRET_KEY=generate_a_secure_random_hex_string_for_production

# ----------------- User Passwords (Production) -----------------
# Required: Secure passwords for the default user accounts in production.
# These replace the default hardcoded demo credentials in backend/main.py.
ADMIN_PASSWORD=change_this_to_a_secure_admin_password_in_production
EMPLOYEE_PASSWORD=change_this_to_a_secure_employee_password_in_production

# ----------------- CORS / Frontend URL -----------------
# Required: The URL of your frontend application to authorize API access.
# For local development: http://localhost:3000
# For production: https://your-frontend-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ----------------- Frontend Configuration -----------------
# Required: URL where the frontend can reach the Backend API.
# In local development: http://localhost:8000
# In production: https://your-backend-app.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000
